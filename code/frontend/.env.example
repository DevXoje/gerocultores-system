# Firebase Configuration (required)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=gero-care

# API URL
VITE_API_URL=http://localhost:3000/api

# ─── Firebase Emulator ──────────────────────────────────────────────────────────
# Set to 'true' to use Firebase Local Emulator Suite (Auth on :9099, Firestore on :8080).
# Requires `firebase emulators:start` running from the `code/` directory.
# Set to 'false' to use a real Firebase project for authentication and Firestore.
#
# Tip: If auth session persistence is not working in the emulator (e.g., refresh
# redirects to login), set this to 'false' and configure a real Firebase project.
VITE_USE_EMULATOR="true"

# ─── Playwright E2E Tests (CI-only, not for local development) ────────────────
# Supplied via CI secrets or .env.test; do NOT set in .env or .env.local
# E2E_USER=
# E2E_PASS=
# PLAYWRIGHT_TEST_BASE_URL=http://localhost:5173