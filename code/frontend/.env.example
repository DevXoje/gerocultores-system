# Copy this file to .env.local and fill in your values
# Firebase Web SDK — client-side config
# NEVER commit a real .env / .env.local file with actual secrets.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id

# Backend API base URL — used by Axios in infrastructure/ layer
# Local dev (Docker Compose): http://localhost:3000
# Staging / production: set to the deployed API URL (e.g. https://api.gerocare.example.com)
VITE_API_URL=http://localhost:3000

# Firebase Emulator — set to "true" in local dev to use local emulators instead of production Firebase
# Set to "false" (or leave empty) in staging/production environments
VITE_USE_EMULATOR=true

# Playwright E2E tests — base URL (optional, defaults to http://localhost:4173)
# Convention from official Playwright CI docs: https://playwright.dev/docs/ci
PLAYWRIGHT_TEST_BASE_URL=http://localhost:4173

# Playwright E2E credentials — authenticated flow (login-agenda.spec.ts)
# Tests that require login are skipped if these are not set.
# In CI, supply these as repository secrets (E2E_USER, E2E_PASS).
E2E_USER=your-test-user@example.com
E2E_PASS=your-test-password

