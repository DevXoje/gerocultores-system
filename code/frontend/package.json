{
  "name": "gerocultores-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{vue,ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,css}\""
  },
  "dependencies": {
    "axios": "1.15.0",
    "firebase": "12.12.0",
    "pinia": "3.0.4",
    "vue": "3.5.32",
    "vue-router": "5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@pinia/testing": "1.0.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "4.2.2",
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "@vitest/coverage-v8": "4.1.4",
    "@vue/test-utils": "2.4.6",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.8.0",
    "jsdom": "29.0.2",
    "prettier": "3.8.3",
    "tailwindcss": "4.2.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.2",
    "vite": "8.0.8",
    "vitest": "4.1.4",
    "vue-tsc": "3.2.6"
  }
}
