rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Utilidades ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function hasRole(rol) {
      return isAuthenticated() && request.auth.token.role == rol;
    }
    function hasAnyRole(roles) {
      return isAuthenticated() && request.auth.token.role in roles;
    }
    function isGerocultor() {
      return hasRole('gerocultor');
    }
    function isAdmin() {
      return hasRole('admin');
    }
    function isAccountOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Safe field read: returns the field value, or null if absent.
    // In Firestore rules v2, accessing a nonexistent field as a VALUE
    // (not in hasAll/hasAny) throws "Null value error".
    // Wrapping in a function that checks hasAll first prevents the error.
    function get(field) {
      return resource.data.keys().hasAll([field]) ? resource.data[field] : null;
    }

    function isResourceOwner() {
      return isAuthenticated() && get('userId') == request.auth.uid;
    }

    // --- Usuarios ---
    match /users/{userId} {
      allow read: if isAccountOwner(userId);
      allow write: if isAdmin();
    }

    // --- Tareas ---
    match /tasks/{tareaId} {
      // Create: cualquier gerocultor autenticado
      allow create: if isAuthenticated();
      // Read/Update: solo el owner (usuarioId == auth.uid)
      allow read: if isAuthenticated() && get('usuarioId') == request.auth.uid;
      allow update: if isAuthenticated() && get('usuarioId') == request.auth.uid;
    }

    // --- Residentes ---
    // Campo gerocultoresAsignados: array de UIDs de gerocultores asignados.
    // Campo archivado: boolean — si true, el residente no aparece en agendas activas.
    function isGerocultorAssignedTo(residenteId) {
      return isAuthenticated() &&
        get('gerocultoresAsignados') != null &&
        request.auth.uid in get('gerocultoresAsignados');
    }

    match /residents/{residenteId} {
      // Modelo descentralizado: cada gerocultor es dueño de los residentes que crea.
      // Create: cualquier gerocultor autenticado (el service asigna usuarioId = requestingUid)
      allow create: if isAuthenticated();
      // Read/Update/Archive: solo el owner (usuarioId == auth.uid)
      allow read: if isAuthenticated() && get('usuarioId') == request.auth.uid;
      allow update: if isAuthenticated() && get('usuarioId') == request.auth.uid;
      // No delete — el archivo es un update que setea archivado=true
    }

    // --- Incidencias ---
    match /incidencias/{incidenciaId} {
      // Create: cualquier gerocultor autenticado
      allow create: if isAuthenticated();
      // Read: solo el owner (usuarioId == auth.uid)
      allow read: if isAuthenticated() && get('usuarioId') == request.auth.uid;
      allow update, delete: if false;
    }

    // --- Notificaciones ---
    match /notificaciones/{notifId} {
      allow read: if isAuthenticated() && (get('usuarioId') == request.auth.uid || isAdmin());
      allow update: if isAuthenticated()
        && get('usuarioId') == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leida']);
      allow create, delete: if false;
    }

    // --- Turnos (colección: 'shifts') ---
    match /shifts/{turnoId} {
      allow read: if isAuthenticated() && (get('usuarioId') == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.usuarioId == request.auth.uid;
      allow update: if isAuthenticated()
        && get('usuarioId') == request.auth.uid
        && !resource.data.keys().hasAll(['fin']);
      allow delete: if false;
    }
  }
}
