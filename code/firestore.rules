rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Utilidades ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function hasRole(rol) {
      return isAuthenticated() && request.auth.token.rol == rol;
    }
    function isGerocultor() {
      return hasRole('gerocultor');
    }
    function isAdministrador() {
      return hasRole('administrador');
    }
    function isAccountOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    // Returns true if the authenticated user is the owner of the resource
    // (resource.data.userId == request.auth.uid).
    function isResourceOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    // Returns true if the residente document is assigned to the authenticated user.
    function isAssignedGerocultor() {
      return isGerocultor() && resource.data.assignedTo == request.auth.uid;
    }


    // --- Usuarios ---
    // Cada usuario sólo puede leer su propio documento;
    // sólo administradores pueden escribir (crear/actualizar roles).
    match /usuarios/{userId} {
      allow read: if isAccountOwner(userId);
      allow write: if isAdministrador();
    }

    // --- Tareas ---
    // Un gerocultor puede leer y actualizar SÓLO sus propias tareas (userId == uid).
    // Administradores tienen acceso completo de lectura/actualización.
    // Gerocultores y administradores pueden crear tareas nuevas.
    match /tareas/{tareaId} {
      allow read: if isResourceOwner() || isAdministrador();
      allow update: if isResourceOwner() || isAdministrador();
      allow create: if isGerocultor() || isAdministrador();
    }

    // --- Residentes ---
    // Administradores tienen acceso completo.
    // Gerocultores pueden leer SÓLO los residentes que tienen asignados
    // (resource.data.assignedTo == request.auth.uid).
    // La escritura queda restringida a administradores.
    match /residentes/{residenteId} {
      allow read: if isAdministrador() || isAssignedGerocultor();
      allow write: if isAdministrador();
    }

    // --- Incidencias ---
    // Gerocultores y administradores pueden crear incidencias.
    // Cualquier usuario autenticado puede leerlas.
    // Actualización y eliminación están prohibidas (inmutabilidad del registro).
    match /incidencias/{incidenciaId} {
      allow create: if isGerocultor() || isAdministrador();
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
