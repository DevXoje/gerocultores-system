
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Utilidades ─────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function hasRole(rol) {
      return isAuthenticated() && request.auth.token.role == rol;
    }

    function hasAnyRole(roles) {
      return isAuthenticated() && request.auth.token.role in roles;
    }

    function isGerocultor() {
      return hasRole('gerocultor');
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isAccountOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Safe field read: returns the field value, or null if absent.
    // In Firestore rules v2, accessing a nonexistent field as a VALUE
    // throws "Null value error". Wrapping in hasAll() prevents it.
    function get(field) {
      return resource.data.keys().hasAll([field]) ? resource.data[field] : null;
    }

    // G04 compliance: entities.md and service code use 'usuarioId' (Spanish)
    // for the ownership field — NOT 'userId'.
    function isResourceOwner() {
      return isAuthenticated() && get('usuarioId') == request.auth.uid;
    }

    // ── users ────────────────────────────────────────────────────────────────
    // Firebase Auth handles authentication.
    // The Firestore document stores additional user profile data (G04 fields).
    // Only the user themselves can read their profile. Admin SDK bypasses rules.
    match /users/{userId} {
      allow read, write: if false;
    }

    // --- Tareas ---
    match /tasks/{tareaId} {
      allow read, write: if false;
    }

    // --- Residentes ---
    match /residents/{residenteId} {
      allow read, write: if false;
    }

    // --- Incidencias ---
    match /incidencias/{incidenciaId} {
      allow read, write: if false;
    }

    // ── notificaciones ───────────────────────────────────────────────────────
    // G04: 'usuarioId' stores the recipient gerocultor's uid.
    // Only the recipient can read their own notifications.
    // Notifications are created by the system (Admin SDK), not by clients.
    match /notificaciones/{notifId} {
      allow read, write: if false;
    }

    // --- Turnos (colección: 'shifts') ---
    match /shifts/{turnoId} {
      allow read, write: if false;
    }
  }
}