rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Utilidades ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function hasRole(rol) {
      return isAuthenticated() && request.auth.token.rol == rol;
    }
    function hasAnyRole(roles) {
      return isAuthenticated() && request.auth.token.rol in roles;
    }
    function isGerocultor() {
      return hasRole('gerocultor');
    }
    function isAdmin() {
      return hasRole('admin');
    }
    function isAccountOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isResourceOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    function isAssignedGerocultor() {
      return isAuthenticated() && resource.data.assignedTo == request.auth.uid;
    }


    // --- Usuarios ---
    // Cada usuario sólo puede leer su propio documento;
    // sólo admins pueden escribir (crear/actualizar roles).
    match /users/{userId} {
      allow read: if isAccountOwner(userId);
      allow write: if isAdmin();
    }

    // --- Tasks ---
    // A gerocultor can read and update ONLY their own tasks (userId == uid).
    // Admins have full read/update access.
    // Gerocultores and admins can create new tasks.
    match /tasks/{taskId} {
      allow read: if isResourceOwner() || isAdmin();
      allow update: if isResourceOwner() || isAdmin();
      allow create: if hasAnyRole(['gerocultor', 'admin']);
    }

    // --- Residents ---
    // Admins have full access.
    // Gerocultores can read ONLY residents assigned to them (assignedTo == uid).
    // Writing is restricted to admins.
    match /residents/{residentId} {
      allow read: if isAdmin() || isAssignedGerocultor();
      allow write: if isAdmin();
    }

    // --- Incidences ---
    // Gerocultores can create incidences.
    // Any authenticated user can read them.
    // Update and delete are prohibited (immutability of the record).
    match /incidences/{incidenceId} {
      allow create: if isGerocultor() || isAdmin();
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }
  }
}
