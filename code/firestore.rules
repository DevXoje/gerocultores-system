rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Utilidades ---
    function isAuthenticated() {
      return request.auth != null;
    }
    function hasRole(rol) {
      return isAuthenticated() && request.auth.token.rol == rol;
    }
    function hasAnyRole(roles) {
      return isAuthenticated() && request.auth.token.rol in roles;
    }
    function isGerocultor() {
      return hasRole('gerocultor');
    }
    function isAdmin() {
      return hasRole('admin');
    }
    function isAccountOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isResourceOwner() {
      return isAuthenticated() && resource.data.userId == request.auth.uid;
    }


    // --- Usuarios ---
    // Cada usuario sólo puede leer su propio documento;
    // sólo admins pueden escribir (crear/actualizar roles).
    match /users/{userId} {
      allow read: if isAccountOwner(userId);
      allow write: if isAdmin();
    }

    // --- Tareas ---
    // Un gerocultor puede leer y actualizar sus propias tareas.
    // Admins tienen acceso completo de lectura/actualización.
    // Sólo roles permitidos pueden crear tareas nuevas.
    match /tasks/{tareaId} {
      allow read: if isResourceOwner() || isAdmin();
      allow update: if isResourceOwner() || isAdmin();
      allow create: if hasAnyRole(['gerocultor', 'admin']);
    }

    // --- Residentes ---
    // Datos sensibles: sólo admins.
    match /residents/{residenteId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // --- Incidencias ---
    // Gerocultores pueden crear incidencias.
    // Cualquier usuario autenticado puede leerlas.
    // Actualización y eliminación están prohibidas (inmutabilidad del registro).
    match /incidencias/{incidenciaId} {
      allow create: if isGerocultor() || isAdmin();
      allow read: if isAuthenticated();
      allow update, delete: if false;
    }

    // --- Notificaciones ---
    // El propietario puede leer y marcar como leída (sólo el campo leida).
    // Admins pueden leer todas. Crear/borrar sólo desde servidor (alertas service).
    match /notificaciones/{notifId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.usuarioId || isAdmin()
      );
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.usuarioId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leida']);
      allow create, delete: if false;
    }

    // --- Turnos (colección: 'shifts') ---
    // El propietario puede leer su propio turno.
    // Los autenticados pueden crear un turno como propietario.
    // El propietario puede actualizar (cerrar) su turno si fin == null.
    // Admins pueden leer todos. No se puede borrar.
    match /shifts/{turnoId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.usuarioId || isAdmin()
      );
      allow create: if isAuthenticated()
        && request.resource.data.usuarioId == request.auth.uid;
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.usuarioId
        && resource.data.fin == null;
      allow delete: if false;
    }
  }
}
