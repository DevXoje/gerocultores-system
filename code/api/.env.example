
# ─── Firebase Admin ──────────────────────────────────────────────────────────────
# Requerido en todos los entornos (local emulators + Cloud Functions).
FIREBASE_PROJECT_ID=gero-care

# ⚠️ SOLO para desarrollo local con emuladores:
#   - En Cloud Functions (producción), se usan ADC (Application Default Credentials)
#     del service accountadjunto a la función. NO pongas estas vars en producción.
#   - Establecer USE_FIREBASE_EMULATORS='true' cuando uses firebase emulators.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Firebase Emulator (desarrollo local) ─────────────────────────────────────
# Solo necesarias cuando USE_FIREBASE_EMULATORS='true'
# (cuando se corre `firebase emulators:start` desde code/)
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
USE_FIREBASE_EMULATORS='true'

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Producción (Cloud Functions) ──────────────────────────────────────────────
# En Cloud Functions desplegado NO se usan estas variables de entorno.
# El SDK de firebase-admin usa Application Default Credentials (ADC)
# del service account de la Cloud Function automáticamente.
# CORS_ORIGIN en producción: establece el dominio de Firebase Hosting
# (ej: https://gero-care.web.app) o '*' si llamas directo a la función.
