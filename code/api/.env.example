# Firebase Admin SDK — service-account credentials
# Copy this file to .env and fill in your values.
# NEVER commit a real .env file with actual credentials.

# Firebase Admin SDK
FIREBASE_PROJECT_ID=gerocultores-system
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Express server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Firebase Emulator Suite — set these when running locally with Docker (`./start_emulators.sh`)
# Nota: Firestore usa el puerto 18080 en el host porque Docker Desktop ocupa el 8080 en macOS.
FIRESTORE_EMULATOR_HOST=localhost:18080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
