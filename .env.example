# Firebase Client (frontend) — Copiar en code/frontend/.env.local
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Admin (backend) — Copiar en code/api/.env
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# API — servidor Express (code/api/.env)
# Puerto en el que escucha la API Express
PORT=3000
# URL base de la API — usada por el frontend Vite (import.meta.env.VITE_API_URL)
VITE_API_URL=http://localhost:3000
# Orígenes CORS permitidos — separar con comas si son varios (p. ej. en producción)
CORS_ORIGIN=http://localhost:5173
# Entorno de ejecución (development | production | test)
NODE_ENV=development